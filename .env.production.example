APP_NAME="Shree Salasar Sarkar"
APP_ENV=production
APP_KEY=                          # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.shreesalasarsarkarfin.com
APP_TIMEZONE=Asia/Kolkata

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shreesalasarsarkar    # Your cPanel DB name
DB_USERNAME=                       # Your cPanel DB username
DB_PASSWORD=                       # Your cPanel DB password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.shreesalasarsarkarfin.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# CORS: allow requests from the frontend domain
FRONTEND_URL=https://shreesalasarsarkarfin.com

# Sanctum stateful domains (for cookie-based auth, not needed for token auth)
SANCTUM_STATEFUL_DOMAINS=shreesalasarsarkarfin.com

MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=mail.shreesalasarsarkarfin.com
MAIL_PORT=465
MAIL_USERNAME=                     # Your mail username
MAIL_PASSWORD=                     # Your mail password
MAIL_FROM_ADDRESS="noreply@shreesalasarsarkarfin.com"
MAIL_FROM_NAME="${APP_NAME}"
